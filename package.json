    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "pinata": "^2.5.5",
    "react": "^19.2.4",
