{
  "private": true,
  "engines": {
    "npm": ">=9.0.0",
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "npx prettier --write \"{__tests__,components,pages,styles,src}/**/*.{ts,tsx,js,jsx}\"",
    "lint": "eslint . && npx prettier --check \"{__tests__,components,pages,styles,src}/**/*.{ts,tsx,js,jsx}\" && npx tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- tsx src/core/database/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:seed": "dotenv -e .env.local -- tsx src/core/database/seed.ts",
    "db:seed-rbac": "dotenv -e .env.local -- tsx src/core/database/seed-rbac.ts"
  },
  "dependencies": {
